# =============================================================
# AI Stack – Environment Configuration
# =============================================================
# Copy this file to .env and fill in the required values:
#
#   cp .env.example .env
#
# .env is gitignored and never committed.
# =============================================================

# =============================================================
# GLOBAL
# =============================================================
RESTART_POLICY=unless-stopped

# =============================================================
# OLLAMA
# =============================================================
OLLAMA_IMAGE=ollama/ollama:latest
OLLAMA_CONTAINER_NAME=aistack-ollama
OLLAMA_PORT=11434
OLLAMA_HOST=0.0.0.0

# Restrict to specific origins in production, e.g.:
# OLLAMA_ORIGINS=http://localhost:3000,https://yourdomain.com
OLLAMA_ORIGINS=*

# VRAM and model limits
OLLAMA_MAX_VRAM=10737418240     # 10 GB
OLLAMA_MAX_LOADED_MODELS=2
OLLAMA_NUM_PARALLEL=2

# =============================================================
# OPEN-WEBUI
# =============================================================
OPENWEBUI_IMAGE=ghcr.io/open-webui/open-webui:main
OPENWEBUI_CONTAINER_NAME=aistack-open-webui
OPENWEBUI_PORT=3000

OLLAMA_BASE_URL=http://aistack-ollama:11434
WEBUI_AUTH=true
WEBUI_NAME=Open WebUI

# Required – generate with: openssl rand -hex 32
WEBUI_SECRET_KEY=

# =============================================================
# COMFYUI
# =============================================================
COMFYUI_IMAGE=yanwk/comfyui-boot:cu128-slim
COMFYUI_CONTAINER_NAME=aistack-comfyui
COMFYUI_PORT=8188
COMFYUI_INTERNAL_PORT=8188

# Memory mode: --normalvram | --lowvram | --highvram
COMFYUI_CLI_ARGS=--normalvram

# =============================================================
# VRAM MANAGER
# =============================================================
VRAM_MANAGER_CONTAINER_NAME=aistack-vram-manager
VRAM_CHECK_INTERVAL=5   # seconds between checks
VRAM_THRESHOLD=75       # free ComfyUI VRAM when GPU usage exceeds this %
